# LiveKit Cloud Credentials
# Get from: https://cloud.livekit.io → your project → Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=SECRETxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXX

# Frontend public URL (used by Caddy/reverse proxy if deployed behind one)
# Leave blank if running without a custom domain
DOMAIN_NAME=
